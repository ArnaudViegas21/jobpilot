# =========================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Python tooling / caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.ipynb_checkpoints/

# Virtual environments
venv/
ENV/
env/
.venv/

# =========================
# 🗄 DATABASES
# =========================
*.db
*.sqlite
*.sqlite3
*.db-journal

# =========================
# 📊 DATA FILES (SAFE FILTER)
# =========================
data/*
!data/sample_applications.csv
!data/sample_jobs.json
!data/resume.example.json

# =========================
