# =========================
# 🔐 ENV / SECRETS (CRITICAL)
# =========================
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# API keys / secrets
secrets.*
*.pem
*.key
*.crt
*.p12

# Python config files that may contain credentials
config.yaml
config.yml
config.local.yaml
secrets.yaml

